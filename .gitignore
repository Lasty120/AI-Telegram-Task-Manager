# --- Окружение и секреты ---
# Секретный файл настроек (содержит токены и пароли от БД)
.env
# Локальные переменные окружения
.env.local
.env.*.local

# --- Кэш Python и виртуальное окружение ---
# Компилированные файлы и кэш
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Виртуальное окружение (встроенное или папки зависимостей)
.venv/
venv/
ENV/
env/

# --- Настройки IDE (PyCharm / IntelliJ IDEA) ---
# Игнорируем папку настроек проекта, кроме конфигураций запуска (если нужны)
.idea/
*.iml

# --- Базы данных и Логи ---
# Логи работы бота
*.log
# Локальные дампы базы данных (если будешь делать)
*.sql
*.dump

# --- Специфичные файлы этого проекта ---
# Итоговый текстовый файл сборки проекта и сам скрипт сборщика (если он локальный)
not_necessary/result.txt
not_necessary/script.py
result.txt
script.py
